# FlowSeer Contact Verifier — Environment Variables
# Copy to .env and fill in your keys
# Free sources (SEC EDGAR, Wikidata, ORCID, OpenCorporates base) need NO keys

# ── Layer 1: Google Programmable Search ──────────────────────────────────────
# Get at: https://console.cloud.google.com → Custom Search JSON API
# Create search engine at: https://programmablesearchengine.google.com
# Free tier: 100 queries/day
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── Layer 4: GitHub ───────────────────────────────────────────────────────────
# Get at: https://github.com/settings/tokens → Personal Access Token
# No special scopes needed — public data only
# Without token: 60 req/hr | With token: 5000 req/hr
GITHUB_TOKEN=

# ── Layer 5: NewsAPI ─────────────────────────────────────────────────────────
# Get at: https://newsapi.org/register
# Free tier: 100 requests/day, 30-day article history
NEWS_API_KEY=

# ── Layer 7: OpenCorporates (optional upgrade) ────────────────────────────────
# Get at: https://opencorporates.com/api_accounts/new
# Without key: 10 req/day | With free key: 500 req/day
OPENCORPORATES_API_KEY=

# ── Layer 9: Hunter ───────────────────────────────────────────────────────────
# Get at: https://hunter.io/api-keys
# Free tier: 50 requests/month (finder + verifier combined)
HUNTER_API_KEY=

# ── Layer 10: Apollo (priority fallback only) ────────────────────────────────
# Get at: https://app.apollo.io/#/settings/integrations/api
# Free plan: limited credits — use sparingly for ACTIVE_RFQ + TIER1 only
APOLLO_API_KEY=
